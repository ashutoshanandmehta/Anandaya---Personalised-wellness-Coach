{
  "name": "health-coach-ai",
  "version": "1.0.0",
  "description": "AI-powered Health Coach Agent — MVP v1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"nodemon server/index.js\" \"vite\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "rag:embed": "node server/scripts/backfillKnowledgeEmbeddings.js",
    "rag:embed:force": "node server/scripts/backfillKnowledgeEmbeddings.js --force",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@huggingface/inference": "^4.13.18",
    "@libsql/sqlite3": "^0.3.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.4.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "groq-sdk": "^1.2.1",
    "helmet": "^8.0.0",
    "marked": "^18.0.5",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "openai": "^6.42.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^11.1.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
