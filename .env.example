PORT=3001
NODE_ENV=development
APP_TIMEZONE=Asia/Kolkata
SCHEDULER_INTERVAL_MS=60000

# Groq model/key slots. Keep keys server-side only.
GROQ_MAIN_OPENAI_1_KEY=
GROQ_MAIN_OPENAI_2_KEY=
GROQ_MAIN_LLAMA70_1_KEY=
GROQ_MAIN_LLAMA70_2_KEY=
GROQ_MAIN_LLAMA_SCOUT_1_KEY=
GROQ_MAIN_LLAMA_SCOUT_2_KEY=

GROQ_PLANNER_QWEN_1_KEY=
GROQ_PLANNER_QWEN_2_KEY=
GROQ_PLANNER_LLAMA8_1_KEY=

GROQ_SUMMARY_LLAMA8_1_KEY=
GROQ_SUMMARY_QWEN_1_KEY=

GROQ_RESERVE_1_KEY=

# Hugging Face is used only for embeddings/RAG.
HF_EMBEDDING_1_TOKEN=
HF_EMBEDDING_2_TOKEN=
HF_EMBEDDING_3_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Temporary migration fallback if slot keys are not configured.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Authentication
SESSION_SECRET=super_secret_session_key_change_me_in_production
DATABASE_PATH=./data/vita.db
# Turso Cloud Database (Optional, replaces DATABASE_PATH if provided)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
ENABLE_SEMANTIC_RAG=false
RAG_EMBEDDING_TIMEOUT_MS=2000
BACKEND_URL=http://localhost:3001
VITE_API_PROXY_TARGET=http://localhost:3001

# Gmail API Configuration (Backend Only)
GMAIL_SENDER_EMAIL=your_email@gmail.com
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REFRESH_TOKEN=your_google_refresh_token

# Set to true to print OTPs in the backend console (ONLY works in development)
ALLOW_DEV_OTP_LOGGING=true

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
